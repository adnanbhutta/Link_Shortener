<header>
  <div class="logo-wrapper">
    <a class="logo nav" href="/" title="Homepage">
      <span>Link</span>_Shortener
    </a>
    <ul class="logo-links">
      {{#if report_email}}
        <li>
          <a class="nav" href="/report" title="Report abuse">
            Report
          </a>
        </li>
      {{/if}}
    </ul>
  </div>
  <nav>
    <ul>
      {{#unless user}}
        {{#unless login_disabled}}
          <li>
            <a class="nav" href="/login" title="Log in">
              Log in
            </a>
          </li>
          <li>
            <a class="button primary" href="/login" title="Sign up">
              Sign up
            </a>
          </li>
        {{/unless}}
      {{/unless}}
      {{#if user}}
        <li>
          <a class="button primary" href="/settings" title="Settings">
            <span>{{> icons/cog}}</span>
            Settings
          </a>
        </li>
        {{#if isAdmin}}
          <li>
            <a class="button secondary" href="/admin" title="Admin">
              <span>{{> icons/shield}}</span>
              Admin
            </a>
          </li>
        {{/if}}
        <li>
          <a class="nav" href="/logout" title="Log out">
            Log out
          </a>
        </li>
      {{/if}}
    </ul>
  </nav>
</header>